# Model Analysis API environment example
# Copy this file to .env on the server and adjust values.

# Service
PORT=8000
DOWNLOAD_DIR=downloads
ASSET_DIR=downloads/assets
MAX_DOWNLOAD_BYTES=314572800
MAX_CONCURRENT_JOBS=10
TASK_RETENTION_SECONDS=86400
PUBLIC_BASE_URL=http://34.219.48.53:8000

# Blender external binary. Linux examples:
#   /usr/bin/blender
#   /usr/local/bin/blender
#   /opt/blender/blender
BLENDER_BIN=/usr/local/bin/blender

# 私有 S3 / S3 兼容存储（百度 BOS、MinIO 等）下载凭证。
# 凭证留服务端、不经请求体传递；请求用 s3://bucket/key 标识对象。
# 仅当 S3_ACCESS_KEY 与 S3_SECRET_KEY 都非空时启用 s3:// 下载。
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-west-2
# 仅对接 S3 兼容存储（BOS/MinIO 等）时设置；标准 AWS S3 留空。
S3_ENDPOINT_URL=
# 可选：临时凭证的 session token。
S3_SESSION_TOKEN=

# Optional OpenAI-compatible settings for future integrations.
# Leave empty if unused.
OPENAI_BASE_URL=
OPENAI_API_KEY=
MIDSCENE_MODEL_NAME=
MIDSCENE_MODEL_FAMILY=
MIDSCENE_REPLANNING_CYCLE_LIMIT=50

# Optional Tripo/Studio integrations. Leave empty if unused.
TRIPO_API_URL_CN_TEST=
TRIPO_API_TOKEN_CN_TEST=
TRIPO_API_URL_CN_PROD=
TRIPO_API_TOKEN_CN_PROD=
TRIPO_API_URL_OVERSEAS_TEST=
TRIPO_API_TOKEN_OVERSEAS_TEST=
TRIPO_API_URL_OVERSEAS_PROD=
TRIPO_API_TOKEN_OVERSEAS_PROD=

STUDIO_URL_CN_TEST=
STUDIO_TOKEN_CN_TEST=
STUDIO_URL_CN_PROD=
STUDIO_TOKEN_CN_PROD=
STUDIO_URL_OVERSEAS_TEST=
STUDIO_TOKEN_OVERSEAS_TEST=
STUDIO_URL_OVERSEAS_PROD=
STUDIO_TOKEN_OVERSEAS_PROD=

# Optional Feishu integration. Leave empty if unused.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
